{
  "manifest_version": 3,
  "version": "1.0.0",
  "description": "Hide comments, reviews, and notifications on Royal Road so you can focus on your writing.",
  "author": "TheBusyBard",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "*://*.royalroad.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Royal GuardRails",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.royalroad.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "hide.css"
      ],
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}